# Get these from your Vercel Integration Console
# https://vercel.com/dashboard/integrations/console
INTEGRATION_CLIENT_ID=your_vercel_integration_client_id
INTEGRATION_CLIENT_SECRET=your_vercel_integration_client_secret
INTEGRATION_SLUG=spark-idx

# Your app URL (set automatically on Vercel)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Spark API - Your master/partner credentials from FBS
SPARK_API_KEY=your_spark_api_key
SPARK_API_SECRET=your_spark_api_secret
